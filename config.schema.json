{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Health Report Config",
  "description": "Configuration schema for Health Report V5.8.1",
  "type": "object",
  "required": [
    "version",
    "members",
    "language"
  ],
  "properties": {
    "version": {
      "type": "string",
      "enum": [
        "5.8.1"
      ],
      "description": "配置版本号"
    },
    "members": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "description": "成员配置列表，最多3人"
    },
    "language": {
      "type": "string",
      "enum": [
        "CN",
        "EN"
      ],
      "description": "报告语言",
      "default": "CN"
    }
  }
}