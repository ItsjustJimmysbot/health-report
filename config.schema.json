{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Health Report Config",
  "description": "Configuration schema for Health Report V6.0.3",
  "type": "object",
  "required": [
    "version",
    "members",
    "language"
  ],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^(5\\.(8|9)|6\\.0)\\.\\d+$",
      "description": "配置版本号，格式: 5.x.x 或 6.0.x"
    },
    "members": {
      "type": "array",
      "minItems": 1,
      "maxItems": 3,
      "description": "成员配置列表，最多3人",
      "items": {
        "type": "object",
        "required": [
          "name",
          "health_dir",
          "workout_dir"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "age": {
            "type": "integer",
            "minimum": 1,
            "maximum": 130
          },
          "gender": {
            "type": "string",
            "enum": [
              "male",
              "female",
              "other"
            ]
          },
          "height_cm": {
            "type": "number",
            "minimum": 50,
            "maximum": 250
          },
          "weight_kg": {
            "type": "number",
            "minimum": 10,
            "maximum": 400
          },
          "health_dir": {
            "type": "string",
            "minLength": 1
          },
          "workout_dir": {
            "type": "string",
            "minLength": 1
          },
          "email": {
            "anyOf": [
              {
                "type": "string",
                "format": "email"
              },
              {
                "type": "string",
                "enum": [
                  ""
                ]
              }
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "analysis_limits": {
      "type": "object",
      "properties": {
        "metric_min_words": {
          "type": "integer",
          "minimum": 1
        },
        "metric_max_words": {
          "type": "integer",
          "minimum": 1
        },
        "action_min_words": {
          "type": "integer",
          "minimum": 1
        },
        "action_max_words": {
          "type": "integer",
          "minimum": 1
        },
        "daily_min_words": {
          "type": "integer",
          "minimum": 1
        },
        "weekly_min_words": {
          "type": "integer",
          "minimum": 1
        },
        "monthly_min_words": {
          "type": "integer",
          "minimum": 1
        },
        "monthly_trend_min_words": {
          "type": "integer",
          "minimum": 1,
          "description": "月报 trend_assessment 最低字数，默认 150"
        },
        "lang_en_max_chinese_ratio_strict": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "EN 严格模式允许的最大中文占比，默认 0.15"
        },
        "lang_en_max_chinese_ratio_warn": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "EN 警告模式允许的最大中文占比，默认 0.20"
        },
        "lang_cn_min_chinese_ratio_strict": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "CN 严格模式要求的最小中文占比，默认 0.30"
        },
        "lang_cn_min_chinese_ratio_warn": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "CN 警告模式要求的最小中文占比，默认 0.20"
        }
      },
      "additionalProperties": true
    },
    "email_config": {
      "type": "object",
      "properties": {
        "provider_priority": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "oauth2",
              "smtp",
              "mail_app",
              "local"
            ]
          }
        },
        "oauth2": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "provider": {
              "type": "string"
            },
            "client_id": {
              "type": "string"
            },
            "client_secret": {
              "type": "string"
            },
            "refresh_token": {
              "type": "string"
            },
            "sender_email": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "email"
                },
                {
                  "type": "string",
                  "enum": [
                    ""
                  ]
                }
              ]
            }
          },
          "additionalProperties": true
        },
        "smtp": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "server": {
              "type": "string"
            },
            "port": {
              "type": "integer"
            },
            "sender_email": {
              "anyOf": [
                {
                  "type": "string",
                  "format": "email"
                },
                {
                  "type": "string",
                  "enum": [
                    ""
                  ]
                }
              ]
            },
            "password": {
              "type": "string"
            },
            "use_tls": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "mail_app": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            }
          },
          "additionalProperties": true
        },
        "local": {
          "type": "object",
          "properties": {
            "enabled": {
              "type": "boolean"
            },
            "output_dir": {
              "type": "string"
            }
          },
          "additionalProperties": true
        },
        "max_retries": {
          "type": "integer",
          "minimum": 1
        },
        "retry_delay": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "receiver_email": {
      "anyOf": [
        {
          "type": "string",
          "format": "email"
        },
        {
          "type": "string",
          "enum": [
            ""
          ]
        }
      ]
    },
    "language": {
      "type": "string",
      "enum": [
        "CN",
        "EN"
      ],
      "description": "报告语言",
      "default": "CN"
    },
    "validation_mode": {
      "type": "string",
      "enum": [
        "strict",
        "warn"
      ],
      "default": "strict"
    },
    "output_dir": {
      "type": "string"
    },
    "cache_dir": {
      "type": "string"
    },
    "log_dir": {
      "type": "string",
      "description": "日志文件保存目录"
    },
    "sleep_config": {
      "type": "object",
      "properties": {
        "read_mode": {
          "type": "string",
          "enum": [
            "next_day",
            "same_day"
          ]
        },
        "start_hour": {
          "type": "integer",
          "minimum": 0,
          "maximum": 23
        },
        "end_hour": {
          "type": "integer",
          "minimum": 0,
          "maximum": 23
        }
      },
      "additionalProperties": true
    },
    "report_metrics": {
      "type": "object",
      "properties": {
        "selected": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "hrv",
              "resting_hr",
              "heart_rate_avg",
              "steps",
              "distance",
              "active_energy",
              "spo2",
              "respiratory_rate",
              "apple_stand_time",
              "basal_energy_burned",
              "vo2_max",
              "physical_effort",
              "sleep_total_hours",
              "sleep_deep_hours",
              "sleep_rem_hours",
              "breathing_disturbances",
              "apple_exercise_time",
              "flights_climbed",
              "apple_stand_hour",
              "stair_speed_up",
              "running_speed",
              "running_power",
              "running_stride_length",
              "running_ground_contact_time",
              "running_vertical_oscillation",
              "walking_speed",
              "walking_step_length",
              "walking_heart_rate_average",
              "walking_asymmetry_percentage",
              "walking_double_support_percentage",
              "headphone_audio_exposure",
              "environmental_audio_exposure"
            ]
          }
        },
        "sort_by_importance": {
          "type": "boolean",
          "default": true
        },
        "show_empty_categories": {
          "type": "boolean",
          "default": true
        },
        "show_sleep_in_metrics_table": {
          "type": "boolean",
          "default": false
        },
        "include_sleep_metrics_in_table": {
          "type": "boolean",
          "description": "兼容旧字段，已废弃，请改用 show_sleep_in_metrics_table"
        },
        "hide_no_data_metrics": {
          "type": "boolean",
          "default": true
        },
        "require_ai_for_selected": {
          "type": "boolean",
          "default": false
        },
        "category_order": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "core_health",
              "cardio_fitness",
              "sleep_recovery",
              "activity_mobility",
              "running_advanced",
              "walking_gait",
              "stairs_strength",
              "environment_audio"
            ]
          }
        },
        "importance_overrides": {
          "type": "object",
          "additionalProperties": {
            "type": "integer",
            "minimum": 0,
            "maximum": 10
          }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": true
}